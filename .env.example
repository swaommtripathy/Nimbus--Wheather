# OpenWeatherMap API Key
REACT_APP_OWM_API_KEY=your_openweathermap_api_key_here

# Firebase Config (for Google Auth)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Email Service (Nodemailer Backend)
# Default: http://localhost:5000 for development
# Change to your server URL for production
REACT_APP_API_URL=http://localhost:5000
